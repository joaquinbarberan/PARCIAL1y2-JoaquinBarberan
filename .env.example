# ============================================================
#  Plantilla de variables de entorno.
#  Copiar como .env y completar con los valores reales.
# ============================================================

# --- Servidor ---
PUERTO=3000

# --- Conexión a PostgreSQL ---
DB_HOST=localhost
DB_PUERTO=5432
DB_USUARIO=postgres
DB_CONTRASENIA=tu_contrasenia
DB_NOMBRE=parcial2

# --- Seguridad / Token de acceso (JWT) ---
JWT_SECRETO=define_una_clave_secreta_larga_y_aleatoria
JWT_EXPIRACION=1h

# --- Cookie de sesión ---
COOKIE_NOMBRE=token_acceso
